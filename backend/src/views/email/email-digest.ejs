<%
  subject = 'Your Docunova weekly digest';
  appUrl  = appUrl || 'https://docunova.app';
%>
<%- await include('partials/_header', { subject, appUrl }) %>

  <h1 style="margin:0 0 16px;font-size:22px;font-weight:700;color:#3d3327;line-height:1.3;">
    Weekly digest
  </h1>
  <p style="margin:0 0 16px;font-size:15px;color:#3d3327;line-height:1.6;">
    Hi <%= name %>,
  </p>
  <p style="margin:0 0 22px;font-size:15px;color:#3d3327;line-height:1.6;">
    Here's your activity summary for the last <strong><%= days %> days</strong>.
  </p>

  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 22px;">
    <tr>
      <td style="background-color:#efe6d8;border:1px solid #dcc8ab;border-radius:8px;padding:14px 16px;">
        <p style="margin:0 0 6px;font-size:14px;color:#3d3327;line-height:1.5;">
          <strong>New documents:</strong> <%= documentCount %>
        </p>
        <p style="margin:0;font-size:14px;color:#3d3327;line-height:1.5;">
          <strong>Searches performed:</strong> <%= searchCount %>
        </p>
      </td>
    </tr>
  </table>

  <% if (newDocuments && newDocuments.length > 0) { %>
    <p style="margin:0 0 10px;font-size:14px;font-weight:600;color:#3d3327;line-height:1.5;">
      Recent uploads
    </p>
    <ul style="margin:0 0 22px;padding-left:18px;">
      <% newDocuments.forEach((document) => { %>
        <li style="margin:0 0 6px;font-size:14px;color:#3d3327;line-height:1.5;">
          <%= document.title %> (<%= new Date(document.uploadedAt).toLocaleDateString() %>)
        </li>
      <% }) %>
    </ul>
  <% } %>

  <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 6px;">
    <tr>
      <td style="border-radius:6px;background-color:#e5c186;">
        <a href="<%= dashboardUrl %>"
           target="_blank"
           style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;
                  color:#3d3327;text-decoration:none;border-radius:6px;letter-spacing:0.2px;">
          Open dashboard
        </a>
      </td>
    </tr>
  </table>

<%- await include('partials/_footer', { appUrl }) %>
