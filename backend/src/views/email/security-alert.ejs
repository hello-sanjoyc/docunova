<%
  subject = subject || 'Security alert';
  appUrl  = appUrl || 'https://docunova.app';
%>
<%- await include('partials/_header', { subject, appUrl }) %>

  <h1 style="margin:0 0 16px;font-size:22px;font-weight:700;color:#3d3327;line-height:1.3;">
    <%= title %>
  </h1>
  <p style="margin:0 0 16px;font-size:15px;color:#3d3327;line-height:1.6;">
    Hi <%= name %>,
  </p>
  <p style="margin:0 0 20px;font-size:15px;color:#3d3327;line-height:1.6;">
    <%= description %>
  </p>

  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 22px;">
    <tr>
      <td style="background-color:#efe6d8;border:1px solid #dcc8ab;border-radius:8px;padding:14px 16px;">
        <p style="margin:0 0 6px;font-size:13px;color:#3d3327;line-height:1.5;">
          <strong>Time:</strong> <%= occurredAt %>
        </p>
        <% if (ipAddress) { %>
          <p style="margin:0 0 6px;font-size:13px;color:#3d3327;line-height:1.5;">
            <strong>IP address:</strong> <%= ipAddress %>
          </p>
        <% } %>
        <% if (userAgent) { %>
          <p style="margin:0;font-size:13px;color:#3d3327;line-height:1.5;word-break:break-word;">
            <strong>Device:</strong> <%= userAgent %>
          </p>
        <% } %>
      </td>
    </tr>
  </table>

  <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 28px;">
    <tr>
      <td style="border-radius:6px;background-color:#e5c186;">
        <a href="<%= securityUrl %>"
           target="_blank"
           style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;
                  color:#3d3327;text-decoration:none;border-radius:6px;letter-spacing:0.2px;">
          Review security settings
        </a>
      </td>
    </tr>
  </table>

  <p style="margin:0;font-size:13px;color:#3d3327;line-height:1.6;">
    If this activity wasn't you, change your password and review active sessions immediately.
  </p>

<%- await include('partials/_footer', { appUrl }) %>
