          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding:24px 40px 32px;">
              <p style="margin:0 0 8px;font-size:13px;color:#9aa5b4;line-height:1.5;">
                © <%= new Date().getFullYear() %> DocuNova AI. All rights reserved.
              </p>
              <p style="margin:0;font-size:12px;color:#b0bac6;line-height:1.5;">
                You received this email because an action was performed on your
                <a href="<%= appUrl %>" style="color:#6c7ee1;text-decoration:none;">Docunova</a> account.
                If you did not initiate this, please ignore this message.
              </p>
            </td>
          </tr>

        </table>

        <!-- Below-card note -->
        <p style="margin:20px 0 0;font-size:12px;color:#9aa5b4;text-align:center;">
          This is an automated message — please do not reply directly to this email.
        </p>
      </td>
    </tr>
  </table>
</body>
</html>
