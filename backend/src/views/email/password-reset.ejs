<%
  subject = 'Reset your password';
  appUrl  = appUrl || 'https://docunova.app';
%>
<%- await include('partials/_header', { subject, appUrl }) %>

  <!-- Greeting -->
  <h1 style="margin:0 0 16px;font-size:22px;font-weight:700;color:#3d3327;line-height:1.3;">
    Reset your password
  </h1>
  <p style="margin:0 0 16px;font-size:15px;color:#3d3327;line-height:1.6;">
    Hi <%= name %>,
  </p>
  <p style="margin:0 0 28px;font-size:15px;color:#3d3327;line-height:1.6;">
    We received a request to reset the password for your Docunova account associated
    with <strong><%= email %></strong>. Click the button below to choose a new password.
  </p>

  <!-- CTA Button -->
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 28px;">
    <tr>
      <td style="border-radius:6px;background-color:#e5c186;">
        <a href="<%= resetUrl %>"
           target="_blank"
           style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;
                  color:#3d3327;text-decoration:none;border-radius:6px;letter-spacing:0.2px;">
          Reset Password
        </a>
      </td>
    </tr>
  </table>

  <!-- Fallback link -->
  <p style="margin:0 0 8px;font-size:13px;color:#3d3327;line-height:1.6;">
    If the button above doesn't work, copy and paste this link into your browser:
  </p>
  <p style="margin:0 0 28px;font-size:13px;line-height:1.6;">
    <a href="<%= resetUrl %>" style="color:#6c7ee1;word-break:break-all;"><%= resetUrl %></a>
  </p>

  <!-- Expiry + security notice -->
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:16px;">
    <tr>
      <td style="background-color:#e3cead;border-left:3px solid #a85f00;border-radius:0 4px 4px 0;padding:12px 16px;">
        <p style="margin:0 0 4px;font-size:13px;color:#3d3327;line-height:1.5;">
          ⏱ This link will expire in <strong><%= expiresInMinutes %> minutes</strong>.
        </p>
        <p style="margin:0;font-size:13px;color:#3d3327;line-height:1.5;">
          🔒 If you did not request a password reset, you can safely ignore this email —
          your password will not change.
        </p>
      </td>
    </tr>
  </table>

<%- await include('partials/_footer', { appUrl }) %>
