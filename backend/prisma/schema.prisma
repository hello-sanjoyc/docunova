generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE    @map("active")
  INVITED   @map("invited")
  SUSPENDED @map("suspended")
  DELETED   @map("deleted")

  @@map("user_status")
}

enum AuthProvider {
  LOCAL     @map("local")
  GOOGLE    @map("google")
  MICROSOFT @map("microsoft")
  GITHUB    @map("github")
  APPLE     @map("apple")
  LINKEDIN  @map("linkedin")
  FACEBOOK  @map("facebook")

  @@map("auth_provider")
}

enum SessionStatus {
  ACTIVE  @map("active")
  REVOKED @map("revoked")
  EXPIRED @map("expired")

  @@map("session_status")
}

enum DocumentStatus {
  UPLOADED   @map("uploaded")
  PROCESSING @map("processing")
  READY      @map("ready")
  FAILED     @map("failed")
  ARCHIVED   @map("archived")
  TRASHED    @map("trashed")

  @@map("document_status")
}

enum AiJobType {
  OCR          @map("ocr")
  CLASSIFY     @map("classify")
  EXTRACT      @map("extract")
  SUMMARIZE    @map("summarize")
  FULL_PROCESS @map("full_process")

  @@map("ai_job_type")
}

enum AiJobStatus {
  QUEUED    @map("queued")
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")
  CANCELLED @map("cancelled")

  @@map("ai_job_status")
}

enum MemberStatus {
  INVITED  @map("invited")
  ACTIVE   @map("active")
  DISABLED @map("disabled")
  REMOVED  @map("removed")

  @@map("member_status")
}

enum OrganizationInvitationStatus {
  PENDING  @map("pending")
  ACCEPTED @map("accepted")
  REVOKED  @map("revoked")
  EXPIRED  @map("expired")

  @@map("organization_invitation_status")
}

enum LimitPeriod {
  LIFETIME @map("lifetime")
  MONTHLY  @map("monthly")
  YEARLY   @map("yearly")
  NONE     @map("none")

  @@map("limit_period")
}

enum SubscriptionStatus {
  ACTIVE    @map("active")
  TRIALING  @map("trialing")
  CANCELLED @map("cancelled")
  EXPIRED   @map("expired")

  @@map("subscription_status")
}

enum BillingCycle {
  MONTHLY @map("monthly")
  YEARLY  @map("yearly")

  @@map("billing_cycle")
}

enum PaymentOrderStatus {
  CREATED
  ATTEMPTED
  PAID
  FAILED
  EXPIRED

  @@map("payment_order_status")
}

enum PaymentTransactionStatus {
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED

  @@map("payment_transaction_status")
}

model Organization {
  id              BigInt   @id @default(autoincrement()) @db.BigInt
  uuid            String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(150)
  logoUrl         String?  @map("logo_url")
  website         String?
  timezone        String   @default("UTC") @db.VarChar(100)
  languageCode    String   @default("en") @map("language_code") @db.VarChar(10)
  planCode        String?  @map("plan_code") @db.VarChar(50)
  billingEmail    String?  @map("billing_email") @db.VarChar(255)
  maxStorageBytes BigInt   @default(0) @map("max_storage_bytes") @db.BigInt
  maxUsers        Int      @default(0) @map("max_users")
  settingsJson    Json     @default("{}") @map("settings_json")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  users                   User[]
  organizationMembers     OrganizationMember[]
  organizationInvitations OrganizationInvitation[]
  folders                 Folder[]
  documents               Document[]
  aiJobs                  AiJob[]
  searchHistory           SearchHistory[]

  @@map("organizations")
}

model User {
  id                    BigInt       @id @default(autoincrement()) @db.BigInt
  uuid                  String       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        BigInt       @map("organization_id") @db.BigInt
  email                 String       @db.VarChar(255)
  passwordHash          String?      @map("password_hash")
  authProvider          AuthProvider @default(LOCAL) @map("auth_provider")
  providerUserId        String?      @map("provider_user_id") @db.VarChar(255)
  firstName             String?      @map("first_name") @db.VarChar(120)
  lastName              String?      @map("last_name") @db.VarChar(120)
  fullName              String?      @map("full_name") @db.VarChar(255)
  phone                 String?      @db.VarChar(30)
  countryCode           String?      @map("country_code") @db.VarChar(2)
  regionCode            String?      @map("region_code") @db.VarChar(20)
  avatarUrl             String?      @map("avatar_url")
  emailVerifiedAt       DateTime?    @map("email_verified_at") @db.Timestamptz(6)
  emailDigestEnabled    Boolean      @default(true) @map("email_digest_enabled")
  securityAlertsEnabled Boolean      @default(true) @map("security_alerts_enabled")
  twoFactorEnabled      Boolean      @default(false) @map("two_factor_enabled")
  twoFactorSecret       String?      @map("two_factor_secret")
  status                UserStatus   @default(ACTIVE)
  lastLoginAt           DateTime?    @map("last_login_at") @db.Timestamptz(6)
  lastActivityAt        DateTime?    @map("last_activity_at") @db.Timestamptz(6)
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?    @map("deleted_at") @db.Timestamptz(6)

  organization                    Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  organizationMembers             OrganizationMember[]     @relation("OrganizationMemberUser")
  invitedOrganizationMembers      OrganizationMember[]     @relation("OrganizationMemberInvitedBy")
  sentOrganizationInvitations     OrganizationInvitation[] @relation("OrganizationInvitationInvitedBy")
  acceptedOrganizationInvitations OrganizationInvitation[] @relation("OrganizationInvitationAcceptedBy")
  userSessions                    UserSession[]
  oauthAccounts                   UserOauthAccount[]
  passwordResetTokens             PasswordResetToken[]
  emailVerificationTokens         EmailVerificationToken[]
  createdFolders                  Folder[]                 @relation("FolderCreatedBy")
  deletedFolders                  Folder[]                 @relation("FolderDeletedBy")
  ownedDocuments                  Document[]               @relation("DocumentOwner")
  deletedDocuments                Document[]               @relation("DocumentDeletedBy")
  documentVersionsCreated         DocumentVersion[]
  documentAccessHistory           DocumentAccessHistory[]
  aiJobsTriggered                 AiJob[]
  searchHistory                   SearchHistory[]
  subscriptions                   Subscription[]
  usageRecords                    UsageRecord[]
  paymentOrders                   PaymentOrder[]
  chatMessages                    DocumentChatMessage[]

  @@unique([organizationId, email], map: "uq_users_org_email")
  @@index([organizationId, email], map: "idx_users_org_email")
  @@index([countryCode], map: "idx_users_country_code")
  @@index([regionCode], map: "idx_users_region_code")
  @@index([status], map: "idx_users_status")
  @@index([deletedAt], map: "idx_users_deleted_at")
  @@map("users")
}

model Plan {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  slug        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(150)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  features      PlanFeature[]
  limits        PlanLimit[]
  prices        PlanPrice[]
  subscriptions Subscription[]
  paymentOrders PaymentOrder[]

  @@index([isActive, sortOrder], map: "idx_plans_active_sort")
  @@map("plans")
}

model Feature {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  key         String   @unique @db.VarChar(150)
  name        String   @db.VarChar(150)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  plans PlanFeature[]

  @@map("features")
}

model PlanFeature {
  id        BigInt  @id @default(autoincrement()) @db.BigInt
  planId    BigInt  @map("plan_id") @db.BigInt
  featureId BigInt  @map("feature_id") @db.BigInt
  included  Boolean @default(true)

  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId], map: "uq_plan_features_plan_feature")
  @@index([featureId], map: "idx_plan_features_feature")
  @@map("plan_features")
}

model PlanLimit {
  id     BigInt      @id @default(autoincrement()) @db.BigInt
  planId BigInt      @map("plan_id") @db.BigInt
  key    String      @db.VarChar(150)
  value  Decimal     @db.Decimal(18, 4)
  period LimitPeriod @default(NONE)

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key], map: "uq_plan_limits_plan_key")
  @@index([key], map: "idx_plan_limits_key")
  @@map("plan_limits")
}

model Region {
  id           BigInt @id @default(autoincrement()) @db.BigInt
  code         String @unique @db.VarChar(20)
  name         String @db.VarChar(150)
  currencyCode String @map("currency_code") @db.VarChar(10)

  prices        PlanPrice[]
  subscriptions Subscription[]
  paymentOrders PaymentOrder[]

  @@map("regions")
}

model PlanPrice {
  id                BigInt   @id @default(autoincrement()) @db.BigInt
  planId            BigInt   @map("plan_id") @db.BigInt
  regionCode        String   @map("region_code") @db.VarChar(20)
  currencyCode      String   @map("currency_code") @db.VarChar(10)
  monthlyPrice      Decimal  @default(0) @map("monthly_price") @db.Decimal(18, 4)
  yearlyPrice       Decimal  @default(0) @map("yearly_price") @db.Decimal(18, 4)
  extraPagePrice    Decimal  @default(0) @map("extra_page_price") @db.Decimal(18, 4)
  extraOcrPagePrice Decimal  @default(0) @map("extra_ocr_page_price") @db.Decimal(18, 4)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  region Region @relation(fields: [regionCode], references: [code], onDelete: Restrict)

  @@unique([planId, regionCode], map: "uq_plan_prices_plan_region")
  @@index([regionCode, isActive], map: "idx_plan_prices_region_active")
  @@map("plan_prices")
}

model Role {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  uuid        String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique(map: "uq_roles_name") @db.VarChar(100)
  code        String   @unique(map: "uq_roles_code") @db.VarChar(100)
  isSystem    Boolean  @default(false) @map("is_system")
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  organizationMembers OrganizationMember[]

  @@map("roles")
}

model OrganizationMember {
  id             BigInt       @id @default(autoincrement()) @db.BigInt
  uuid           String       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId BigInt       @map("organization_id") @db.BigInt
  userId         BigInt       @map("user_id") @db.BigInt
  roleId         BigInt?      @map("role_id") @db.BigInt
  title          String?      @db.VarChar(150)
  status         MemberStatus @default(ACTIVE)
  invitedBy      BigInt?      @map("invited_by") @db.BigInt
  invitedAt      DateTime?    @map("invited_at") @db.Timestamptz(6)
  joinedAt       DateTime?    @map("joined_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User         @relation("OrganizationMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  role          Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  invitedByUser User?        @relation("OrganizationMemberInvitedBy", fields: [invitedBy], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId], map: "uq_org_member")
  @@index([organizationId], map: "idx_org_members_org")
  @@index([userId], map: "idx_org_members_user")
  @@index([roleId], map: "idx_org_members_role")
  @@map("organization_members")
}

model OrganizationInvitation {
  id             BigInt                       @id @default(autoincrement()) @db.BigInt
  uuid           String                       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId BigInt                       @map("organization_id") @db.BigInt
  email          String                       @db.VarChar(255)
  roleCode       String?                      @map("role_code") @db.VarChar(100)
  tokenHash      String                       @map("token_hash")
  status         OrganizationInvitationStatus @default(PENDING)
  invitedBy      BigInt?                      @map("invited_by") @db.BigInt
  acceptedBy     BigInt?                      @map("accepted_by") @db.BigInt
  expiresAt      DateTime                     @map("expires_at") @db.Timestamptz(6)
  acceptedAt     DateTime?                    @map("accepted_at") @db.Timestamptz(6)
  revokedAt      DateTime?                    @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                     @default(now()) @map("updated_at") @db.Timestamptz(6)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedByUser  User?        @relation("OrganizationInvitationInvitedBy", fields: [invitedBy], references: [id], onDelete: SetNull)
  acceptedByUser User?        @relation("OrganizationInvitationAcceptedBy", fields: [acceptedBy], references: [id], onDelete: SetNull)

  @@index([organizationId, status], map: "idx_org_invitations_org_status")
  @@index([organizationId, email], map: "idx_org_invitations_org_email")
  @@index([tokenHash], map: "idx_org_invitations_token")
  @@map("organization_invitations")
}

model UserSession {
  id               BigInt        @id @default(autoincrement()) @db.BigInt
  uuid             String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           BigInt        @map("user_id") @db.BigInt
  refreshTokenHash String        @map("refresh_token_hash")
  deviceName       String?       @map("device_name") @db.VarChar(255)
  deviceType       String?       @map("device_type") @db.VarChar(50)
  browser          String?       @db.VarChar(100)
  os               String?       @db.VarChar(100)
  ipAddress        String?       @map("ip_address") @db.VarChar(45)
  userAgent        String?       @map("user_agent")
  status           SessionStatus @default(ACTIVE)
  lastSeenAt       DateTime?     @map("last_seen_at") @db.Timestamptz(6)
  expiresAt        DateTime      @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime?     @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status], map: "idx_sessions_user_status")
  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@map("user_sessions")
}

model UserOauthAccount {
  id                    BigInt       @id @default(autoincrement()) @db.BigInt
  uuid                  String       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                BigInt       @map("user_id") @db.BigInt
  provider              AuthProvider
  providerUserId        String       @map("provider_user_id") @db.VarChar(255)
  providerEmail         String?      @map("provider_email") @db.VarChar(255)
  scope                 String?
  accessTokenEncrypted  String?      @map("access_token_encrypted")
  refreshTokenEncrypted String?      @map("refresh_token_encrypted")
  tokenExpiresAt        DateTime?    @map("token_expires_at") @db.Timestamptz(6)
  profileJson           Json         @default("{}") @map("profile_json")
  lastLoginAt           DateTime?    @map("last_login_at") @db.Timestamptz(6)
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId], map: "uq_oauth_provider_user")
  @@unique([userId, provider], map: "uq_user_oauth_provider")
  @@index([provider, lastLoginAt(sort: Desc)], map: "idx_oauth_accounts_provider_last_login")
  @@index([userId, provider], map: "idx_oauth_accounts_user_provider")
  @@map("user_oauth_accounts")
}

model OauthCallbackState {
  id               BigInt       @id @default(autoincrement()) @db.BigInt
  provider         AuthProvider
  stateHash        String       @unique @map("state_hash") @db.Char(64)
  codeVerifierHash String?      @map("code_verifier_hash") @db.Char(64)
  source           String       @default("login") @db.VarChar(30)
  targetPath       String?      @map("target_path")
  redirectUri      String       @map("redirect_uri")
  ipAddress        String?      @map("ip_address") @db.Inet
  userAgent        String?      @map("user_agent")
  metadataJson     Json         @default("{}") @map("metadata_json")
  expiresAt        DateTime     @map("expires_at") @db.Timestamptz(6)
  consumedAt       DateTime?    @map("consumed_at") @db.Timestamptz(6)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([provider, expiresAt], map: "idx_oauth_callback_provider_expires")
  @@map("oauth_callback_states")
}

model PasswordResetToken {
  id        BigInt    @id @default(autoincrement()) @db.BigInt
  userId    BigInt    @map("user_id") @db.BigInt
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_password_reset_user")
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         BigInt    @id @default(autoincrement()) @db.BigInt
  userId     BigInt    @map("user_id") @db.BigInt
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_email_verification_user")
  @@map("email_verification_tokens")
}

model Folder {
  id             BigInt    @id @default(autoincrement()) @db.BigInt
  uuid           String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId BigInt    @map("organization_id") @db.BigInt
  parentId       BigInt?   @map("parent_id") @db.BigInt
  createdBy      BigInt    @map("created_by") @db.BigInt
  name           String    @db.VarChar(255)
  pathCache      String?   @map("path_cache")
  color          String?   @db.VarChar(20)
  description    String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy      BigInt?   @map("deleted_by") @db.BigInt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent        Folder?      @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children      Folder[]     @relation("FolderToFolder")
  createdByUser User         @relation("FolderCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  deletedByUser User?        @relation("FolderDeletedBy", fields: [deletedBy], references: [id], onDelete: SetNull)
  documents     Document[]

  @@index([organizationId, parentId], map: "idx_folders_org_parent")
  @@index([deletedAt], map: "idx_folders_deleted_at")
  @@map("folders")
}

model Document {
  id                  BigInt         @id @default(autoincrement()) @db.BigInt
  uuid                String         @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      BigInt         @map("organization_id") @db.BigInt
  folderId            BigInt?        @map("folder_id") @db.BigInt
  ownerUserId         BigInt         @map("owner_user_id") @db.BigInt
  currentVersionId    BigInt?        @map("current_version_id") @db.BigInt
  title               String         @db.VarChar(500)
  originalFilename    String         @map("original_filename") @db.VarChar(500)
  storageKey          String         @map("storage_key")
  previewStorageKey   String?        @map("preview_storage_key")
  thumbnailStorageKey String?        @map("thumbnail_storage_key")
  mimeType            String         @map("mime_type") @db.VarChar(150)
  fileExtension       String?        @map("file_extension") @db.VarChar(20)
  fileSizeBytes       BigInt         @map("file_size_bytes") @db.BigInt
  checksumSha256      String?        @map("checksum_sha256") @db.Char(64)
  pageCount           Int?           @map("page_count")
  languageCode        String?        @map("language_code") @db.VarChar(10)
  status              DocumentStatus @default(UPLOADED)
  sourceType          String         @default("upload") @map("source_type") @db.VarChar(50)
  isFavoriteCount     Int            @default(0) @map("is_favorite_count")
  metadataJson        Json           @default("{}") @map("metadata_json")
  uploadedAt          DateTime       @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  updatedAt           DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?      @map("deleted_at") @db.Timestamptz(6)
  deletedBy           BigInt?        @map("deleted_by") @db.BigInt

  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  folder          Folder?                  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  owner           User                     @relation("DocumentOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  currentVersion  DocumentVersion?         @relation("DocumentCurrentVersion", fields: [currentVersionId], references: [id], onDelete: NoAction)
  deletedByUser   User?                    @relation("DocumentDeletedBy", fields: [deletedBy], references: [id], onDelete: SetNull)
  versions        DocumentVersion[]        @relation("DocumentVersions")
  accessHistory   DocumentAccessHistory[]
  aiJobs          AiJob[]
  ocrResult       DocumentOcrResult?
  aiSummaries     DocumentAiSummary[]
  classifications DocumentClassification[]
  usageRecords    UsageRecord[]
  chunks          DocumentChunk[]
  chatMessages    DocumentChatMessage[]

  @@index([organizationId, folderId], map: "idx_documents_org_folder")
  @@index([ownerUserId], map: "idx_documents_owner")
  @@index([status], map: "idx_documents_status")
  @@index([deletedAt], map: "idx_documents_deleted_at")
  @@index([uploadedAt(sort: Desc)], map: "idx_documents_uploaded_at")
  @@index([currentVersionId], map: "idx_documents_current_version")
  @@index([metadataJson], type: Gin, map: "idx_documents_metadata_gin")
  @@map("documents")
}

model Subscription {
  id                 BigInt             @id @default(autoincrement()) @db.BigInt
  userId             BigInt             @map("user_id") @db.BigInt
  planId             BigInt             @map("plan_id") @db.BigInt
  regionCode         String             @map("region_code") @db.VarChar(20)
  status             SubscriptionStatus @default(ACTIVE)
  billingCycle       BillingCycle       @map("billing_cycle")
  startedAt          DateTime           @default(now()) @map("started_at") @db.Timestamptz(6)
  currentPeriodStart DateTime           @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd   DateTime           @map("current_period_end") @db.Timestamptz(6)
  cancelledAt        DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  region       Region        @relation(fields: [regionCode], references: [code], onDelete: Restrict)
  usageRecords UsageRecord[]
  paymentOrders PaymentOrder[]

  @@index([userId, status], map: "idx_subscriptions_user_status")
  @@index([planId], map: "idx_subscriptions_plan")
  @@index([regionCode], map: "idx_subscriptions_region")
  @@index([currentPeriodEnd], map: "idx_subscriptions_period_end")
  @@map("subscriptions")
}

model UsageRecord {
  id             BigInt   @id @default(autoincrement()) @db.BigInt
  userId         BigInt   @map("user_id") @db.BigInt
  subscriptionId BigInt?  @map("subscription_id") @db.BigInt
  documentId     BigInt?  @map("document_id") @db.BigInt
  pagesUsed      Int      @default(0) @map("pages_used")
  ocrPagesUsed   Int      @default(0) @map("ocr_pages_used")
  // Stored for future internal cost analytics. Token pricing is intentionally
  // not exposed to customers while billing is page-based.
  tokensUsed     Int?     @map("tokens_used")
  usageMonth     DateTime @map("usage_month") @db.Date
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  document     Document?     @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([userId, usageMonth], map: "idx_usage_records_user_month")
  @@index([subscriptionId, usageMonth], map: "idx_usage_records_subscription_month")
  @@index([documentId], map: "idx_usage_records_document")
  @@map("usage_records")
}

model DocumentVersion {
  id                  BigInt   @id @default(autoincrement()) @db.BigInt
  uuid                String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId          BigInt   @map("document_id") @db.BigInt
  versionNumber       Int      @map("version_number")
  storageKey          String   @map("storage_key")
  previewStorageKey   String?  @map("preview_storage_key")
  thumbnailStorageKey String?  @map("thumbnail_storage_key")
  fileSizeBytes       BigInt   @map("file_size_bytes") @db.BigInt
  mimeType            String   @map("mime_type") @db.VarChar(150)
  checksumSha256      String?  @map("checksum_sha256") @db.Char(64)
  pageCount           Int?     @map("page_count")
  createdBy           BigInt   @map("created_by") @db.BigInt
  versionNote         String?  @map("version_note")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  document            Document   @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  createdByUser       User       @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  currentForDocuments Document[] @relation("DocumentCurrentVersion")

  @@unique([documentId, versionNumber], map: "uq_document_version")
  @@index([documentId, createdAt(sort: Desc)], map: "idx_document_versions_doc_created_at")
  @@map("document_versions")
}

model DocumentAccessHistory {
  id         BigInt   @id @default(autoincrement()) @db.BigInt
  documentId BigInt   @map("document_id") @db.BigInt
  userId     BigInt   @map("user_id") @db.BigInt
  accessedAt DateTime @default(now()) @map("accessed_at") @db.Timestamptz(6)
  accessType String   @map("access_type") @db.VarChar(50)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, accessedAt(sort: Desc)], map: "idx_doc_access_user_time")
  @@index([documentId, accessedAt(sort: Desc)], map: "idx_doc_access_doc_time")
  @@map("document_access_history")
}

model AiJob {
  id              BigInt      @id @default(autoincrement()) @db.BigInt
  uuid            String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  BigInt      @map("organization_id") @db.BigInt
  documentId      BigInt      @map("document_id") @db.BigInt
  triggeredBy     BigInt?     @map("triggered_by") @db.BigInt
  jobType         AiJobType   @map("job_type")
  status          AiJobStatus @default(QUEUED)
  providerName    String?     @map("provider_name") @db.VarChar(100)
  modelName       String?     @map("model_name") @db.VarChar(150)
  priority        Int         @default(5) @db.SmallInt
  progressPercent Decimal     @default(0) @map("progress_percent") @db.Decimal(5, 2)
  inputJson       Json        @default("{}") @map("input_json")
  outputJson      Json        @default("{}") @map("output_json")
  errorMessage    String?     @map("error_message")
  startedAt       DateTime?   @map("started_at") @db.Timestamptz(6)
  completedAt     DateTime?   @map("completed_at") @db.Timestamptz(6)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document                Document                 @relation(fields: [documentId], references: [id], onDelete: Cascade)
  triggeredByUser         User?                    @relation(fields: [triggeredBy], references: [id], onDelete: SetNull)
  documentOcrResults      DocumentOcrResult[]
  documentAiSummaries     DocumentAiSummary[]
  documentClassifications DocumentClassification[]

  @@index([documentId, createdAt(sort: Desc)], map: "idx_ai_jobs_doc")
  @@index([organizationId, status], map: "idx_ai_jobs_org_status")
  @@index([status], map: "idx_ai_jobs_status")
  @@index([jobType], map: "idx_ai_jobs_type")
  @@index([inputJson], type: Gin, map: "idx_ai_jobs_input_gin")
  @@index([outputJson], type: Gin, map: "idx_ai_jobs_output_gin")
  @@map("ai_jobs")
}

enum OcrStatus {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  COMPLETED  @map("completed")
  FAILED     @map("failed")
  SKIPPED    @map("skipped")

  @@map("ocr_status")
}

model DocumentOcrResult {
  id               BigInt    @id @default(autoincrement()) @db.BigInt
  documentId       BigInt    @unique(map: "uq_document_ocr_result") @map("document_id") @db.BigInt
  aiJobId          BigInt?   @map("ai_job_id") @db.BigInt
  extractedText    String?   @map("extracted_text")
  pageTextJson     Json      @default("[]") @map("page_text_json")
  confidenceScore  Decimal?  @map("confidence_score") @db.Decimal(5, 2)
  languageDetected String?   @map("language_detected") @db.VarChar(20)
  ocrStatus        OcrStatus @default(PENDING) @map("ocr_status")
  ocrMethod        String?   @map("ocr_method") @db.VarChar(50)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  aiJob    AiJob?   @relation(fields: [aiJobId], references: [id], onDelete: SetNull)

  @@index([documentId], map: "idx_ocr_doc")
  @@map("document_ocr_results")
}

model DocumentAiSummary {
  id              BigInt   @id @default(autoincrement()) @db.BigInt
  documentId      BigInt   @map("document_id") @db.BigInt
  aiJobId         BigInt?  @map("ai_job_id") @db.BigInt
  summaryType     String   @default("general") @map("summary_type") @db.VarChar(50)
  summaryText     String   @map("summary_text")
  keyPointsJson   Json     @default("[]") @map("key_points_json")
  confidenceScore Decimal? @map("confidence_score") @db.Decimal(5, 2)
  providerName    String?  @map("provider_name") @db.VarChar(100)
  modelName       String?  @map("model_name") @db.VarChar(150)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  aiJob    AiJob?   @relation(fields: [aiJobId], references: [id], onDelete: SetNull)

  @@index([documentId, summaryType], map: "idx_summaries_doc_type")
  @@map("document_ai_summaries")
}

model DocumentClassification {
  id              BigInt   @id @default(autoincrement()) @db.BigInt
  documentId      BigInt   @map("document_id") @db.BigInt
  aiJobId         BigInt?  @map("ai_job_id") @db.BigInt
  classLabel      String   @map("class_label") @db.VarChar(150)
  confidenceScore Decimal  @map("confidence_score") @db.Decimal(5, 2)
  isPrimary       Boolean  @default(false) @map("is_primary")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  aiJob    AiJob?   @relation(fields: [aiJobId], references: [id], onDelete: SetNull)

  @@index([documentId], map: "idx_classifications_doc")
  @@index([documentId, isPrimary], map: "idx_classifications_primary")
  @@map("document_classifications")
}

model SearchHistory {
  id             BigInt   @id @default(autoincrement()) @db.BigInt
  organizationId BigInt   @map("organization_id") @db.BigInt
  userId         BigInt   @map("user_id") @db.BigInt
  queryText      String   @map("query_text")
  queryType      String   @default("basic") @map("query_type") @db.VarChar(30)
  filtersJson    Json     @default("{}") @map("filters_json")
  resultCount    Int?     @map("result_count")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_search_history_user_time")
  @@index([organizationId, createdAt(sort: Desc)], map: "idx_search_history_org_time")
  @@map("search_history")
}

model PaymentOrder {
  id              BigInt             @id @default(autoincrement()) @db.BigInt
  uuid            String             @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          BigInt             @map("user_id") @db.BigInt
  planId          BigInt             @map("plan_id") @db.BigInt
  regionCode      String             @map("region_code") @db.VarChar(20)
  billingCycle    BillingCycle       @map("billing_cycle")
  razorpayOrderId String             @unique @map("razorpay_order_id") @db.VarChar(100)
  amount          Decimal            @db.Decimal(18, 4)
  currencyCode    String             @map("currency_code") @db.VarChar(10)
  status          PaymentOrderStatus @default(CREATED)
  subscriptionId  BigInt?            @map("subscription_id") @db.BigInt
  notes           Json?
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan                 @relation(fields: [planId], references: [id], onDelete: Restrict)
  region       Region               @relation(fields: [regionCode], references: [code], onDelete: Restrict)
  subscription Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  transactions PaymentTransaction[]

  @@index([userId], map: "idx_payment_orders_user")
  @@index([razorpayOrderId], map: "idx_payment_orders_rzp_order")
  @@index([status], map: "idx_payment_orders_status")
  @@map("payment_orders")
}

model PaymentTransaction {
  id                BigInt                   @id @default(autoincrement()) @db.BigInt
  paymentOrderId    BigInt                   @map("payment_order_id") @db.BigInt
  razorpayPaymentId String                   @unique @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature String?                  @map("razorpay_signature") @db.Text
  amount            Decimal                  @db.Decimal(18, 4)
  currencyCode      String                   @map("currency_code") @db.VarChar(10)
  status            PaymentTransactionStatus
  method            String?                  @db.VarChar(50)
  bank              String?                  @db.VarChar(100)
  wallet            String?                  @db.VarChar(100)
  vpa               String?                  @db.VarChar(100)
  cardNetwork       String?                  @map("card_network") @db.VarChar(50)
  cardLast4         String?                  @map("card_last4") @db.VarChar(4)
  email             String?                  @db.VarChar(255)
  contact           String?                  @db.VarChar(20)
  errorCode         String?                  @map("error_code") @db.VarChar(100)
  errorDescription  String?                  @map("error_description") @db.Text
  rawPayload        Json?                    @map("raw_payload")
  capturedAt        DateTime?                @map("captured_at") @db.Timestamptz(6)
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)

  order PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)

  @@index([paymentOrderId], map: "idx_payment_txn_order")
  @@index([razorpayPaymentId], map: "idx_payment_txn_rzp_payment")
  @@map("payment_transactions")
}

model WebhookEvent {
  id          BigInt    @id @default(autoincrement()) @db.BigInt
  source      String    @db.VarChar(50)
  eventType   String    @map("event_type") @db.VarChar(100)
  entityId    String    @map("entity_id") @db.VarChar(100)
  payload     Json
  status      String    @default("received") @db.VarChar(20)
  errorMsg    String?   @map("error_msg") @db.Text
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([source, eventType], map: "idx_payment_webhook_events_source_type")
  @@index([entityId], map: "idx_payment_webhook_events_entity")
  @@map("payment_webhook_events")
}

model DocumentChunk {
  id         BigInt   @id @default(autoincrement()) @db.BigInt
  documentId BigInt   @map("document_id") @db.BigInt
  chunkIndex Int      @map("chunk_index")
  content    String
  pageNumber Int?     @map("page_number")
  startChar  Int      @map("start_char")
  endChar    Int      @map("end_char")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, chunkIndex], map: "idx_doc_chunks_doc_index")
  @@map("document_chunks")
}

model DocumentChatMessage {
  id         BigInt   @id @default(autoincrement()) @db.BigInt
  uuid       String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId BigInt   @map("document_id") @db.BigInt
  userId     BigInt   @map("user_id") @db.BigInt
  role       String   @db.VarChar(20)
  content    String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId, userId, createdAt(sort: Desc)], map: "idx_chat_messages_doc_user")
  @@map("document_chat_messages")
}
