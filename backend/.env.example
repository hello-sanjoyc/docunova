NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# CORS
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL="XXX"

# Redis
REDIS_HOST=XXX.XXX.XXX.XXX
REDIS_PORT=XXX
REDIS_USERNAME=XXX
REDIS_PASSWORD=XXX
REDIS_TLS=false
REDIS_CONNECT_TIMEOUT_MS=5000

# JWT
JWT_SECRET="XXX"
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID="XXX"
GOOGLE_CLIENT_SECRET="XXX"
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/google/callback"
FRONTEND_APP_URL="http://localhost:3000"


# AI / LLM — provider: "openai" or "groq"
AI_PROVIDER="XXX"
AI_MODEL_NAME="XXX"
AI_MODEL_API_KEY="XXX"

# SMTP 
SMTP_HOST="XXX"
SMTP_PORT=587
SMTP_USER="XXX"
SMTP_PASS="XXX"
SMTP_SECURE=false
MAIL_FROM_NAME="DocuNova AI"
MAIL_FROM_EMAIL="no-reply@docunova.app"

# Document configuration
DOCUMENT_STORAGE_PATH="documents"
DOCUMENT_STORAGE_LIMIT=10737418240 # 10 GB in bytes
MAX_DOCUMENT_PAGES=50
RECENT_DAYS=30

# Storage in "aws" or "gcp" or "azure" or "s3"
STORAGE_PROVIDER="s3" 
S3_ENDPOINT="https://idr01.zata.ai"
S3_BUCKET="XXX"
S3_ACCESS_KEY_ID="XXX"
S3_SECRET_ACCESS_KEY="XXX"
S3_REGION="CentralIndia"
S3_URL="XXX"
